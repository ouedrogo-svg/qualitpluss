# Copiez ce fichier en .env et adaptez les valeurs (ne commitez jamais .env).

# Obligatoire
SECRET_KEY=changez-moi-une-cle-secrete-longue-et-aleatoire

# Local : True | Render : false
DEBUG=True

# Base de données (Render fournit DATABASE_URL automatiquement)
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE

# Ancien nom encore accepté par settings.py :
# DATABASES_URL=postgresql://USER:PASSWORD@HOST/DATABASE

# Local (optionnel — Render remplit RENDER_EXTERNAL_HOSTNAME tout seul)
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Sur Render, ajoutez aussi (remplacez par votre URL) :
# ALLOWED_HOSTS=votre-app.onrender.com
# CSRF_TRUSTED_ORIGINS=https://votre-app.onrender.com
